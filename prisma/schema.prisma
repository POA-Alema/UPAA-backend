// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "mongodb"
  url      = env("DATABASE_URL")
}

model User {
  id        String   @id @default(auto()) @map("_id") @db.ObjectId
  email     String   @unique
  password  String
  name      String?
  role      Role     @default(ADMIN)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model Construction {
  id          String   @id @default(auto()) @map("_id") @db.ObjectId
  title       String
  description String?
  latitude    Float
  longitude   Float
  address     String?
  buildYear   Int?     
  architect   String?  
  images      String[] // URLs das imagens no S3
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

}

enum Role {
  USER
  ADMIN
}

sources           String[] // lista de fontes

  // imagens por categoria
  floorPlans        String[] // planta baixa
  facades           String[]
  externalPhotos    String[]
  internalPhotos    String[]

  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt
